{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-title",
    "dialog:allow-open",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "shell:allow-open"
  ]
}